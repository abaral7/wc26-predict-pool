# Copy to .env.local for local dev. On Vercel, set these in Project Settings -> Environment Variables.

# User PIN — required to view the pool at all. Shared with all pool members.
USER_PIN=change-me-view

# Admin PIN — the only secret that unlocks editing. Server-side check, never shipped to the browser.
ADMIN_PIN=change-me-1234

# DB adapter: "upstash" (default) or "api". Omit to use Upstash.
DB_ADAPTER=upstash

# --- Upstash adapter (DB_ADAPTER=upstash) ---
# Added automatically when you connect Upstash from the Vercel Marketplace.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- API adapter (DB_ADAPTER=api) ---
# Points to your own backend. The backend must expose GET /pool and PUT /pool.
API_BASE_URL=https://your-backend.example.com/api
API_SECRET=your-secret-token

# --- predictthefootball.com integration ---
# Log into worldcup.predictthefootball.com in Chrome, open DevTools → Network,
# click any /minileague request and copy the cookie header values below.
# Session cookies expire — re-copy after each login.
# You can also paste these in admin Settings → PTF Integration instead of using env vars.
PTF_LEAGUE_ID=16363
PTF_SESSION=your-PHPSESSID-value
PTF_CSRF=your-YII_CSRF_TOKEN-value
