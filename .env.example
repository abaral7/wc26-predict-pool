# Copy to .env.local for local dev. On Vercel, set these in Project Settings -> Environment Variables.

# User PIN — required to view the pool at all. Shared with all pool members.
USER_PIN=change-me-view

# Admin PIN — the only secret that unlocks editing. Server-side check, never shipped to the browser.
ADMIN_PIN=change-me-1234

# Upstash Redis (added automatically when you connect Upstash from the Vercel Marketplace)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
